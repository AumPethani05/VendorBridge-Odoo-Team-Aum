generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                     Int       @id @default(autoincrement())
  photo                  String?   @db.VarChar(255)
  first_name             String    @db.VarChar(100)
  last_name              String    @db.VarChar(100)
  email                  String    @unique @db.VarChar(255)
  phone_number           String    @db.VarChar(20)
  country                String    @db.VarChar(100)
  additional_information String?
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  updated_at             DateTime? @default(now()) @db.Timestamp(6)
  password               String    @db.VarChar(255)
  username               String    @unique @db.VarChar(100)
  role                   String    @db.VarChar(50)
}

model vendors {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  email      String   @unique @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  category   String?  @db.VarChar(100)
  gst_no     String?  @db.VarChar(20)
  status     String   @default("active") @db.VarChar(50)
  rating     Decimal? @default(0) @db.Decimal(2, 1)
  address    String?
  created_at DateTime @default(now()) @db.Timestamp(6)
  rfqs       rfqs[]
  pos        purchase_orders[]
  quotations quotations[]
}

model rfqs {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?
  category    String?  @db.VarChar(100)
  deadline    DateTime?
  status      String   @default("draft") @db.VarChar(50)
  vendor_id   Int
  vendor      vendors  @relation(fields: [vendor_id], references: [id])
  created_at  DateTime @default(now()) @db.Timestamp(6)
  line_items  rfq_line_items[]
  quotations  quotations[]
  approvals   approval_chain[]
}

model rfq_line_items {
  id          Int     @id @default(autoincrement())
  rfq_id      Int
  rfq         rfqs    @relation(fields: [rfq_id], references: [id])
  item_name   String  @db.VarChar(255)
  quantity    Int
  unit        String  @db.VarChar(50)
  quote_items quote_items[]
}

model quotations {
  id          Int      @id @default(autoincrement())
  rfq_id      Int
  rfq         rfqs     @relation(fields: [rfq_id], references: [id])
  vendor_id   Int
  vendor      vendors  @relation(fields: [vendor_id], references: [id])
  subtotal    Decimal  @db.Decimal(12, 2)
  tax_percent Decimal  @default(18) @db.Decimal(5, 2)
  grand_total Decimal  @db.Decimal(12, 2)
  status      String   @default("pending") @db.VarChar(50)
  notes       String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  quote_items quote_items[]
}

model quote_items {
  id           Int        @id @default(autoincrement())
  quote_id     Int
  quote        quotations @relation(fields: [quote_id], references: [id])
  rfq_item_id  Int
  rfq_item     rfq_line_items @relation(fields: [rfq_item_id], references: [id])
  unit_price   Decimal    @db.Decimal(12, 2)
  delivery_days Int?
}

model approval_chain {
  id          Int      @id @default(autoincrement())
  rfq_id      Int
  rfq         rfqs     @relation(fields: [rfq_id], references: [id])
  approver    String   @db.VarChar(255)
  role        String   @db.VarChar(100)
  status      String   @default("pending") @db.VarChar(50)
  approved_at DateTime?
  remarks     String?
}

model purchase_orders {
  id         Int      @id @default(autoincrement())
  po_number  String   @unique @db.VarChar(100)
  vendor_id  Int
  vendor     vendors  @relation(fields: [vendor_id], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  status     String   @default("draft") @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(6)
  invoices   invoices[]
}

model invoices {
  id         Int             @id @default(autoincrement())
  invoice_no String          @unique @db.VarChar(100)
  po_id      Int
  po         purchase_orders @relation(fields: [po_id], references: [id])
  amount     Decimal         @db.Decimal(12, 2)
  status     String          @default("unpaid") @db.VarChar(50)
  due_date   DateTime?       @db.Date
  created_at DateTime        @default(now()) @db.Timestamp(6)
}
